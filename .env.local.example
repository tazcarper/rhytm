# ============================================================================
# .env.local.example  —  LOCAL development config for contributors
# ============================================================================
# Copy this file to `.env.local` (which is gitignored and never committed).
#
#   cp .env.local.example .env.local
#
# Almost everything here is generated on YOUR machine — no secrets are sent to
# you, and NONE of these point at production. The local Supabase stack runs in
# Docker on your computer; the keys below are local-only and harmless.
#
# Claude fills in the Supabase values for you on first setup by reading
# `npx supabase status`. You normally don't edit this by hand.
# ============================================================================

# ---- Supabase (LOCAL stack — from `npx supabase status`) -------------------
# Constant for the local stack:
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Paste the local "anon key" printed by `npx supabase status`:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Paste the local "service_role key" printed by `npx supabase status`.
# This bypasses row-level security, but ONLY on your local Docker database, so
# it is not sensitive. Never put a production key here.
SUPABASE_SECRET_KEY=

# ---- Bid page cookie secret (generate locally) -----------------------------
# Any random value works locally. Generate one with:
#   openssl rand -base64 32
BID_COOKIE_SECRET=

# ---- Stripe (OPTIONAL — leave blank for layout/CSS work) -------------------
# Only needed if you want the deposit/payment UI to actually run locally.
# Use TEST-MODE keys only (sk_test_… / pk_test_…). NEVER a live key.
# Ask your developer for a test key via a one-time secret link if you need it.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Waiver (homegrown/native is the default — needs nothing) --------------
# Leave WAIVER_PROVIDER unset to use the built-in native waiver locally.

# ---- Inngest (workflows) — local dev mode ----------------------------------
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

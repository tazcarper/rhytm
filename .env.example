# Supabase
# Public URL and anon key — safe to ship to the browser. The anon key
# is gated by the project's RLS policies; without RLS allowing a read,
# this key gives no access.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — bypasses RLS. Server-side ONLY. Never expose to
# the browser, never put in NEXT_PUBLIC_*, never log. Used by Server
# Actions and Route Handlers for operations that cross user boundaries
# (checkout, webhooks, member seeding, the public bid page fetch).
SUPABASE_SERVICE_ROLE_KEY=

# Signing secret for the bid-page session cookie (Phase 3 access-code flow).
# Generate with: openssl rand -base64 32
BID_COOKIE_SECRET=

# Webhook signing secrets (Phase 6 — required before live webhooks)
STRIPE_WEBHOOK_SECRET=
DROPBOX_SIGN_WEBHOOK_SECRET=

# Supabase
# Public URL and publishable key — safe to ship to the browser. The
# publishable key is gated by the project's RLS policies; without RLS
# allowing a read, this key gives no access. (Replaces the legacy
# `anon` key; same security model, opaque format `sb_publishable_…`.)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key — bypasses RLS. Server-side ONLY. Never expose to the
# browser, never put in NEXT_PUBLIC_*, never log. Used by Server
# Actions and Route Handlers for operations that cross user boundaries
# (checkout, webhooks, member seeding, the public bid page fetch).
# (Replaces the legacy `service_role` key; same effect at the Postgres
# layer — Supabase still authenticates this key as the `service_role`
# Postgres role — opaque format `sb_secret_…`.)
SUPABASE_SECRET_KEY=

# Signing secret for the bid-page session cookie (Phase 3 access-code flow).
# Generate with: openssl rand -base64 32
BID_COOKIE_SECRET=

# Stripe (App 6 — deposit collection on the public bid page).
# Test mode keys start with sk_test_… / pk_test_…; live keys start
# with sk_live_… / pk_live_…. Grab from Stripe dashboard → Developers
# → API keys (with test-mode toggle ON).
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret (Phase 6 — required before live webhooks).
# For local dev: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and copy the whsec_… it prints. For prod: create a webhook endpoint
# in the dashboard and copy the signing secret it generates there.
STRIPE_WEBHOOK_SECRET=

# Waiver signing provider (App 7).
# DEFAULT = homegrown "native" waiver: typed signature -> pdf-lib PDF ->
# private Supabase Storage `waivers` bucket -> record_bid_signature RPC.
# It needs NO extra env vars — it reuses NEXT_PUBLIC_SUPABASE_URL +
# SUPABASE_SECRET_KEY above, plus the `waivers` bucket (created by
# migration 20260531140000) in your Supabase project. So in Vercel there
# is nothing to set: leaving WAIVER_PROVIDER unset uses the homegrown flow.
#
# Set WAIVER_PROVIDER=dropbox_sign ONLY to revert to the deprecated vendor
# path below (see src/services/dropbox-sign/DEPRECATED.md). The native and
# vendor paths are mutually exclusive — selected by this one switch.
# WAIVER_PROVIDER=native

# ---- DEPRECATED: Dropbox Sign (only used when WAIVER_PROVIDER=dropbox_sign) ----
# The vendor e-sign path, kept intact as a revivable fallback. The values
# below are NOT needed for the default native waiver — leave them blank
# unless you flip the provider above. When the provider is dropbox_sign and
# these are unset, that path stays dormant: bid pages render the existing
# SignatureSlot placeholder; confirmBid logs a "Dropbox Sign disabled"
# warning and skips envelope creation; the webhook route returns 503.
#
# Setup steps (one-time, requires Dropbox Sign account):
#   1. Get API key from Settings → API → API Keys.
#   2. Create an API app at Settings → API → API Apps for the
#      embedded signing client_id. The redirect domain should be
#      your production deploy (e.g. rhytm-one.vercel.app).
#   3. On the API app's edit page, add the webhook URL:
#      https://<your-domain>/api/webhooks/dropbox-sign
#   4. Upload the waiver PDF as a template; place signer fields
#      (signature, name auto-fill, date auto-fill). Use signer role
#      "Guest". Copy template id.
DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_TEMPLATE_ID=
# Exposed to the browser bundle so the hellosign-embedded client SDK
# can initialize. Not a secret on its own — anyone visiting your bid
# page can read it. Also read server-side for envelope creation
# (single source of truth — no parallel non-public version).
NEXT_PUBLIC_DROPBOX_SIGN_CLIENT_ID=

# OPTIONAL: only set if your Dropbox Sign account surfaces a distinct
# "Callback Signing Key" (paid plans sometimes do). Free / typical
# setups don't — the API key above is also the HMAC secret, and the
# webhook handler falls back to DROPBOX_SIGN_API_KEY when this is unset.
DROPBOX_SIGN_WEBHOOK_SECRET=

# Inngest (App 9 — workflow engine).
#
# Local dev:
#   1. npx inngest-cli@latest dev
#      → http://localhost:8288 (Inngest UI, auto-discovers the local
#        Next.js dev server's /api/inngest route)
#   2. Set INNGEST_DEV=1 in .env.local. The Inngest 4.x SDK no longer
#      infers dev mode from NODE_ENV; without this flag the client runs
#      in "cloud" mode and the serve handler will reject the dev
#      server's requests for missing INNGEST_SIGNING_KEY. With it,
#      signature verification and event-key checks are skipped and the
#      INNGEST_EVENT_KEY / INNGEST_SIGNING_KEY values below can stay
#      blank locally.
#
# Production / Vercel: both keys required (no INNGEST_DEV).
#
#   INNGEST_EVENT_KEY  — authenticates `inngest.send({ name, data })`
#                        calls from Server Actions / webhook handlers.
#                        Get from Inngest dashboard → Manage → Event Keys.
#                        Missing in cloud mode → inngest.send() throws.
#
#   INNGEST_SIGNING_KEY — used by app/api/inngest/route.ts to verify
#                         incoming step executions are genuinely from
#                         Inngest. Get from Inngest dashboard → Manage →
#                         Signing Key. Missing in cloud mode → serve
#                         handler rejects every incoming request.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
